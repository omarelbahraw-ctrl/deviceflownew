generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

model User {
  id        String   @id @default(cuid())
  name      String
  username  String   @unique
  password  String   // Hashed password
  role      Role     @default(EMPLOYEE)
  
  // Specific permissions (JSON or simple booleans)
  canManageTraders Boolean @default(false)
  canManageBatches Boolean @default(true)  // Receiving & Inspection
  canManageDiscount Boolean @default(false) // Discount Warehouse

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Trader {
  id                 String   @id @default(cuid())
  name               String   // اسم المؤسسة
  phone              String   // هاتف المؤسسة
  contactPerson      String?  // اسم المسئول
  representative     String?  // المندوب التابع له
  email              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  batches            Batch[]
  devices            Device[]
}

enum BatchStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

model Batch {
  id             String      @id @default(cuid())
  traderId       String
  date           DateTime    @default(now())
  status         BatchStatus @default(OPEN)
  closedAt       DateTime?
  reportNumber   String?     // رقم البلاغ / بلاغ العميل
  representative String?     // اسم المندوب

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  trader         Trader      @relation(fields: [traderId], references: [id])
  items          BatchItem[] // الأصناف المتوقع استلامها في هذا الإذن
  devices        Device[]    // الأجهزة الفعلية التي تم استلامها
}

model BatchItem {
  id               String   @id @default(cuid())
  batchId          String
  brand            String   // البراند
  deviceType       String   // نوع الجهاز (شاشات، مكيفات، الخ)
  model            String   // الموديل
  expectedQuantity Int      // العدد المتوقع

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  batch            Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

enum Condition {
  NEW
  USED
}

enum CartonStatus {
  GOOD
  DAMAGED
  NONE
}

enum InspectionResult {
  PENDING
  MATCH
  NOT_MATCH
}

enum Decision {
  PENDING
  ACCEPT
  RETURN
  DISCOUNT
  IN_WORKSHOP
  READY_FOR_DELIVERY
  REPAIRED_AND_DELIVERED
  REPAIRED_BUT_REJECTED
  REJECTED_AND_DELIVERY_REJECTED
  NON_COMPLIANT_NOT_RECEIVED
  NON_COMPLIANT_RECEIVED_WITH_OVERRIDE
  RETURNED_COMPLIANT
}

model Device {
  id               String           @id @default(cuid())
  batchId          String
  traderId         String
  brand            String           @default("غير محدد") // البراند
  type             String           // نوع الجهاز
  model            String           // الموديل
  serialNumber     String           @unique
  condition        Condition
  cartonStatus     CartonStatus
  accessoriesStatus String?         // الملحقات (كامل ملحقاته، غير كامل ملحقاته)
  inspectionResult InspectionResult @default(PENDING)
  faultType        String?          // خانة العطل (يعمل، لا يعمل، مكسور، خط، دوت، بانل)
  defectType       String?          // تفاصيل إضافية للعيب
  decision         Decision         @default(PENDING)
  inspectorName    String?
  inspectionDate   DateTime?
  notes            String?          // التقرير الفني والملاحظات
  discountCategory DiscountCategory @default(B)
  imageBase64      String?          // صورة حالة الجهاز (Base64)
  mediaUrls        String[]         @default([]) // روابط الصور والفيديوهات من Vercel Blob

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  batch            Batch            @relation(fields: [batchId], references: [id])
  trader           Trader           @relation(fields: [traderId], references: [id])
  images           DeviceImage[]
  discountItem     DiscountWarehouse?
}

enum ImageType {
  FRONT
  BACK
  SERIAL
  DEFECT
  CARTON
}

model DeviceImage {
  id         String    @id @default(cuid())
  deviceId   String
  imagePath  String
  imageType  ImageType

  createdAt  DateTime  @default(now())

  device     Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

enum DiscountCategory {
  A
  B
  C
}

enum WorkingStatus {
  WORKING
  MINOR_ISSUE
  NEEDS_REPAIR
}

model DiscountWarehouse {
  id              String           @id @default(cuid())
  deviceId        String?          @unique
  category        DiscountCategory
  workingStatus   WorkingStatus

  // بيانات الجهاز (مستقل عن Device)
  brand           String?
  model           String?
  type            String?
  serialNumber    String?
  
  // تفاصيل الإصلاح
  previousIssue   String?          // المشكلة السابقة
  repairDone      String?          // ما تم إصلاحه
  accessories     String?          // الملحقات المتاحة
  displayNotes    String?
  
  // الأسعار
  priceBefore     Float?
  discountPercent Float?
  priceAfter      Float?
  repairCost      Float?
  readyForSale    Boolean          @default(true)

  // صور الجهاز (base64)
  image1          String?          // صورة الجهاز الرئيسية
  image2          String?          // صورة إضافية
  image3          String?          // صورة الملحقات

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  device          Device?          @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   // JSON encoded array of strings
  updatedAt DateTime @updatedAt
}

model SparePart {
  id               String            @id @default(cuid())
  name             String            // اسم القطعة
  code             String            @unique // كود القطعة
  compatibleModels String            // الموديلات المتوافقة
  quantity         Int               @default(0) // الكمية المتوفرة
  minQuantity      Int               @default(5) // الحد الأدنى للطلب
  price            Float?            // السعر (اختياري)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  transactions     PartTransaction[]
}

model PartTransaction {
  id          String    @id @default(cuid())
  partId      String
  type        String    // "IN" (إدخال) أو "OUT" (صرف)
  quantity    Int       // الكمية
  recipient   String?   // المستلم (لصرف القطعة) أو المورد (للإدخال)
  reference   String?   // رقم البلاغ أو أمر الصيانة المرتبط
  notes       String?   // ملاحظات
  date        DateTime  @default(now())
  
  part        SparePart @relation(fields: [partId], references: [id], onDelete: Cascade)
}
