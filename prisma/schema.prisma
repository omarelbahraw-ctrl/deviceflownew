generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

model User {
  id        String   @id @default(cuid())
  name      String
  username  String   @unique
  password  String   // Hashed password
  role      Role     @default(EMPLOYEE)
  
  // Specific permissions (JSON or simple booleans)
  canManageTraders Boolean @default(false)
  canManageBatches Boolean @default(true)  // Receiving & Inspection
  canManageDiscount Boolean @default(false) // Discount Warehouse

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Trader {
  id                 String   @id @default(cuid())
  name               String   // اسم المؤسسة
  phone              String   // هاتف المؤسسة
  contactPerson      String?  // اسم المسئول
  representative     String?  // المندوب التابع له
  email              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  batches            Batch[]
  devices            Device[]
}

enum BatchStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

model Batch {
  id        String      @id @default(cuid())
  traderId  String
  date      DateTime    @default(now())
  status    BatchStatus @default(OPEN)
  closedAt  DateTime?

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  trader    Trader      @relation(fields: [traderId], references: [id])
  items     BatchItem[] // الأصناف المتوقع استلامها في هذا الإذن
  devices   Device[]    // الأجهزة الفعلية التي تم استلامها
}

model BatchItem {
  id               String   @id @default(cuid())
  batchId          String
  brand            String   // البراند
  deviceType       String   // نوع الجهاز (شاشات، مكيفات، الخ)
  model            String   // الموديل
  expectedQuantity Int      // العدد المتوقع

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  batch            Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

enum Condition {
  NEW
  USED
}

enum CartonStatus {
  GOOD
  DAMAGED
  NONE
}

enum InspectionResult {
  PENDING
  MATCH
  NOT_MATCH
}

enum Decision {
  PENDING
  ACCEPT
  RETURN
  DISCOUNT
}

model Device {
  id               String           @id @default(cuid())
  batchId          String
  traderId         String
  brand            String           @default("غير محدد") // البراند
  type             String           // نوع الجهاز
  model            String           // الموديل
  serialNumber     String           @unique
  condition        Condition
  cartonStatus     CartonStatus
  accessoriesStatus String?         // الملحقات (كامل ملحقاته، غير كامل ملحقاته)
  inspectionResult InspectionResult @default(PENDING)
  faultType        String?          // خانة العطل (يعمل، لا يعمل، مكسور، خط، دوت، بانل)
  defectType       String?          // تفاصيل إضافية للعيب
  decision         Decision         @default(PENDING)
  inspectorName    String?
  inspectionDate   DateTime?
  notes            String?          // التقرير الفني والملاحظات
  imageBase64      String?          // صورة حالة الجهاز (Base64)

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  batch            Batch            @relation(fields: [batchId], references: [id])
  trader           Trader           @relation(fields: [traderId], references: [id])
  images           DeviceImage[]
  discountItem     DiscountWarehouse?
}

enum ImageType {
  FRONT
  BACK
  SERIAL
  DEFECT
  CARTON
}

model DeviceImage {
  id         String    @id @default(cuid())
  deviceId   String
  imagePath  String
  imageType  ImageType

  createdAt  DateTime  @default(now())

  device     Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

enum DiscountCategory {
  A
  B
  C
}

enum WorkingStatus {
  WORKING
  MINOR_ISSUE
  NEEDS_REPAIR
}

model DiscountWarehouse {
  id              String           @id @default(cuid())
  deviceId        String?          @unique
  category        DiscountCategory
  workingStatus   WorkingStatus

  // بيانات الجهاز (مستقل عن Device)
  brand           String?
  model           String?
  type            String?
  serialNumber    String?
  
  // تفاصيل الإصلاح
  previousIssue   String?          // المشكلة السابقة
  repairDone      String?          // ما تم إصلاحه
  accessories     String?          // الملحقات المتاحة
  displayNotes    String?
  
  // الأسعار
  priceBefore     Float?
  discountPercent Float?
  priceAfter      Float?
  repairCost      Float?
  readyForSale    Boolean          @default(true)

  // صور الجهاز (base64)
  image1          String?          // صورة الجهاز الرئيسية
  image2          String?          // صورة إضافية
  image3          String?          // صورة الملحقات

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  device          Device?          @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}
